# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/corporate-commitment-monitor

# Server port
PORT=5000

# Classification — Hugging Face is tried first if set, then OpenAI, then keyword mock.

# Hugging Face Inference API (https://huggingface.co/settings/tokens)
HUGGINGFACE_API_TOKEN=
# Zero-shot model (default: facebook/bart-large-mnli)
# HUGGINGFACE_MODEL=facebook/bart-large-mnli

# OpenAI — optional fallback
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
